{
  "name": "stock-dashboard-v3-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check:static-data": "node scripts/check-static-data.mjs",
    "generate:snapshot": "node scripts/generate-v3-snapshot.mjs",
    "generate:snapshot:sample": "node scripts/generate-v3-snapshot.mjs --input fixtures/snapshot-input.sample.json --out tmp/generated-v3-snapshot-sample",
    "smoke:routes": "node scripts/smoke-routes.mjs",
    "smoke:api-mode": "node scripts/smoke-api-mode.mjs",
    "pipeline:manual": "node scripts/run-v3-manual-pipeline.mjs",
    "pipeline:manual:sample": "node scripts/run-v3-manual-pipeline.mjs --input fixtures/snapshot-input.sample.json --out tmp/manual-pipeline-snapshot-sample",
    "pipeline:print-next-steps": "node scripts/print-api-validation-steps.mjs",
    "db:export-seed": "node scripts/export-snapshot-to-sql.mjs",
    "db:export-seed:sample": "node scripts/export-snapshot-to-sql.mjs --data-root tmp/manual-pipeline-snapshot-sample --out tmp/v3-seed-sample.sql",
    "db:init-sample": "npm run pipeline:manual:sample && npm run db:export-seed:sample && node scripts/init-sample-db.mjs",
    "market:update-live": "node scripts/update-live-market-data.mjs",
    "pipeline:write-db": "node scripts/write-v3-pipeline-to-db.mjs",
    "pipeline:write-db:dry-run": "node scripts/write-v3-pipeline-to-db.mjs --dry-run",
    "pipeline:write-db:test": "node scripts/write-v3-pipeline-to-db.mjs --test-db tmp/v3-pipeline-test.db",
    "intraday:checkpoint:dry-run": "node scripts/run-v3-intraday-checkpoint.mjs --dry-run",
    "intraday:checkpoint:write": "node scripts/run-v3-intraday-checkpoint.mjs --write",
    "data:refresh": "node scripts/refresh-v3-public-data.mjs",
    "symbols:refresh-universe": "node scripts/refresh-symbol-universe.mjs",
    "ai:usage": "node scripts/print-ai-usage-summary.mjs",
    "premarket:plan:generate": "node scripts/generate-v3-premarket-plan.mjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "iron-session": "^8.0.2",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^0.460.0",
    "next": "^16.0.0",
    "next-themes": "^0.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-config-next": "^16.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
