# Mode switches (UI-level feature flags)
# Values: mock | static-file | api
NEXT_PUBLIC_DATA_MODE=mock
# Values: published | live
NEXT_PUBLIC_AI_MODE=published
# Values: curated | stream
NEXT_PUBLIC_NEWS_MODE=curated
# Values: tradingview | native | provider-x
NEXT_PUBLIC_CHART_MODE=tradingview

# Static file source (used when NEXT_PUBLIC_DATA_MODE=static-file)
NEXT_PUBLIC_STATIC_DATA_BASE=/data

# API base URL (used when NEXT_PUBLIC_DATA_MODE=api).
# The built-in Next.js route handlers live at /api/v3 and read from public/data
# (or V3_API_DATA_ROOT if set), so the default works for local development.
NEXT_PUBLIC_API_BASE_URL=/api/v3

# Server-side data root for the /api/v3 route handlers.
# Defaults to <cwd>/public/data when unset.
# V3_API_DATA_ROOT=

# SQLite DB path (server-side, used when V3_API_SOURCE=db)
V3_SQLITE_DB_PATH=tmp/v3-sample.db

# API source mode: static-file | db
V3_API_SOURCE=static-file

# ── Auth (login system) ───────────────────────────────────────────────────────
# If ALL THREE vars below are set, the site is protected by login.
# If any is missing, the login gate is disabled and the site is fully accessible.
#
# 1. Generate a bcrypt hash of your password:
#      node scripts/hash-password.mjs
#    Then paste the output here (the full $2b$... string).
#
# 2. Generate a random SESSION_SECRET (>= 32 chars):
#      openssl rand -base64 32
#    Or any long random string.
AUTH_USERNAME=admin
AUTH_PASSWORD_HASH=
SESSION_SECRET=
